# Dockerfile.iox — OpenClaw IOx custom container (pyATS edition)
#
# Target platforms:
#   linux/amd64  — Catalyst 9300/9400/9500, ISR 4000, CSR 1000v
#   linux/arm64  — Catalyst 9800-L, IR1800, some IR1101 variants
#   linux/arm/v7 — IR1101 (IOS XE 16.12+)
#
# After building, package for IOx with:
#   ioxclient docker package openclaw-iox:latest . --use-targz
#
# Required env vars at runtime (pass via IOx app config or docker run -e):
#   OPENCLAW_GATEWAY_TOKEN — bearer token protecting the gateway API (also used by agents to connect back)
#   ANTHROPIC_API_KEY      — or whichever provider key you use
#   WEBEX_BOT_TOKEN        — if using the Webex channel plugin

FROM --platform=linux/amd64 debian:bookworm-slim

ARG NODE_VERSION=22
ARG OPENCLAW_VERSION=latest

# --- Base env ---
ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    # Puts the pyATS venv on PATH for all subsequent RUN steps and at runtime
    PATH="/opt/pyats/bin:$PATH" \
    # Node/npm global prefix
    NPM_CONFIG_PREFIX=/usr/local

# --- System dependencies ---
RUN apt-get update && apt-get install -y --no-install-recommends \
    # Core utilities
    curl \
    ca-certificates \
    gnupg \
    # Python (pyATS requires 3.8+; bookworm ships 3.11)
    python3 \
    python3-pip \
    python3-venv \
    # SSH client — required for pyATS to connect to device management plane
    openssh-client \
    # lsof — required by openclaw gateway --force to check for stale pid files
    lsof \
    # Useful for troubleshooting inside the container
    iputils-ping \
    && rm -rf /var/lib/apt/lists/*

# --- ngrok (HTTP tunnel — used when NGROK_AUTHTOKEN is set and no WEBEX_WEBHOOK_URL is provided) ---
RUN curl -fsSL https://ngrok-agent.s3.amazonaws.com/ngrok.asc \
        | tee /etc/apt/trusted.gpg.d/ngrok.asc >/dev/null \
    && echo "deb https://ngrok-agent.s3.amazonaws.com buster main" \
        | tee /etc/apt/sources.list.d/ngrok.list \
    && apt-get update \
    && apt-get install -y --no-install-recommends ngrok \
    && rm -rf /var/lib/apt/lists/*

# --- Node.js 22 (via NodeSource) ---
RUN curl -fsSL https://deb.nodesource.com/setup_${NODE_VERSION}.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && rm -rf /var/lib/apt/lists/* \
    && node --version \
    && npm --version

# --- pyATS (base + genie only — full install is ~1.5 GB, avoid it) ---
# pyats: core framework, connection management, job runner
# genie: structured parsers for 700+ IOS XE show commands, config modeling
RUN python3 -m venv /opt/pyats \
    && /opt/pyats/bin/pip install --no-cache-dir \
        pyats \
        genie \
    && /opt/pyats/bin/python3 -c "import pyats; import genie; print('pyATS OK')"

# --- OpenClaw gateway ---
RUN npm install -g openclaw@${OPENCLAW_VERSION} \
    && openclaw --version

# --- Plugin SDK shims for webex and cisco-syslog ---
# The published openclaw package does not include dist/plugin-sdk/webex.js or
# dist/plugin-sdk/cisco-syslog.js. Each extension's runtime-api.ts imports from
# "openclaw/plugin-sdk/<id>" which needs the barrel to exist. The install scripts
# copy CJS shims that re-export from individual plugin-sdk subpaths, plus inline
# the inbound-envelope helper. If a future openclaw version ships the real barrels,
# each script is a no-op.
COPY docker/plugin-sdk-webex-shim.js /tmp/docker/plugin-sdk-webex-shim.js
COPY docker/install-webex-shim.mjs /tmp/docker/install-webex-shim.mjs
RUN node /tmp/docker/install-webex-shim.mjs
COPY docker/plugin-sdk-cisco-syslog-shim.js /tmp/docker/plugin-sdk-cisco-syslog-shim.js
COPY docker/install-cisco-syslog-shim.mjs /tmp/docker/install-cisco-syslog-shim.mjs
RUN node /tmp/docker/install-cisco-syslog-shim.mjs

# --- Plugin installation ---
# Option A (recommended): install plugins from npm once they are published.
#   Uncomment the lines below and remove the COPY block (Option B).
#
# RUN openclaw plugin install @openclaw/webex @openclaw/cisco-syslog

# Option B: install plugins from local source (current state — not yet published).
#   Copies the built extension directories into the image and installs deps.
COPY extensions/webex /opt/openclaw-plugins/webex
COPY extensions/cisco-syslog /opt/openclaw-plugins/cisco-syslog
COPY extensions/cisco-pyats /opt/openclaw-plugins/cisco-pyats

RUN cd /opt/openclaw-plugins/webex \
    && npm pkg delete devDependencies \
    && npm install --omit=dev \
    && cd /opt/openclaw-plugins/cisco-syslog \
    && npm pkg delete devDependencies \
    && npm install --omit=dev \
    && cd /opt/openclaw-plugins/cisco-pyats \
    && npm pkg delete devDependencies \
    && npm install --omit=dev

# Default pyATS testbed path — generated at container startup by the entrypoint
# from DEVICE_HOST / DEVICE_USERNAME / DEVICE_OS env vars.
ENV OPENCLAW_PYATS_TESTBED="/root/.openclaw/testbed.yaml"

# --- Default agent personality files ---
# Seeded into the volume by the entrypoint on first start if not already present.
# Override by editing /root/.openclaw/agents/main/agent/SOUL.md inside the container.
COPY docker/agent-soul.md /opt/openclaw-defaults/agent-soul.md
COPY docker/agent-tools.md /opt/openclaw-defaults/agent-tools.md

# --- Runtime config directory ---
# Mount a persistent volume here to survive container restarts:
#   -v openclaw-data:/root/.openclaw
RUN mkdir -p /root/.openclaw/credentials /root/.openclaw/sessions

# --- Entrypoint ---
COPY docker/iox-entrypoint.sh /usr/local/bin/entrypoint.sh
RUN chmod +x /usr/local/bin/entrypoint.sh

# --- Exposed ports ---
# 18789   — OpenClaw gateway (HTTP + WebSocket)
# 5514    — Syslog receiver UDP + TCP (avoid 514 to skip root requirement)
# 9000    — Cisco MDT telemetry HTTP (dial-out)
EXPOSE 18789
EXPOSE 5514/udp
EXPOSE 5514/tcp
EXPOSE 9000

WORKDIR /root

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
